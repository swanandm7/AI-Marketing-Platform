# DegreeBaba Hub — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to version control.

# ── Frontend (Vite) ─────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:3001
VITE_HUB_API_KEY=                         # Must match HUB_API_KEY below

# ── Server ──────────────────────────────────────────────────────
PORT=3001
HUB_API_KEY=                              # Shared secret — set the same in VITE_HUB_API_KEY
CORS_ORIGIN=http://localhost:5173         # Frontend dev server origin

# ── Anthropic ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ── Database (PostgreSQL via Prisma) ────────────────────────────
DATABASE_URL=                             # postgresql://user:pass@host:5432/db

# ── Google (GSC + GA4 + Ads — single OAuth app) ─────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GA4_PROPERTY_ID=
GSC_SITE_URL=                             # e.g. https://www.degreebaba.com/
GOOGLE_ADS_DEVELOPER_TOKEN=
GOOGLE_ADS_CUSTOMER_ID=                   # e.g. 123-456-7890

# ── Meta ────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=                        # Long-lived token — expires every 60 days
META_AD_ACCOUNT_ID=                       # e.g. act_123456789

# ── LinkedIn ────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_ACCESS_TOKEN=
LINKEDIN_AD_ACCOUNT_ID=

# ── Microsoft Clarity ───────────────────────────────────────────
CLARITY_PROJECT_ID=
CLARITY_API_KEY=

# ── Pabbly Webhook ──────────────────────────────────────────────
PABBLY_WEBHOOK_SECRET=                    # Shared secret for webhook verification
